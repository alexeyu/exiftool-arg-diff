{
  "name": "exiftool-arg-diff",
  "version": "0.1.0",
  "description": "Diff old/new metadata into the minimal exiftool CLI args needed to apply the change.",
  "keywords": [
    "exiftool",
    "metadata",
    "exif",
    "iptc",
    "xmp",
    "diff"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexeyu/exiftool-arg-diff.git"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/node": "^26.1.0",
    "exiftool-vendored": "^36.0.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
